# Build-time secrets — copy to `.env` for local builds, and set the same
# values in the Netlify dashboard under Site settings → Environment variables.
# These are read by src/lib/portfolio.ts at build time to populate the
# /portfolio pages from the shared Supabase project. If either is missing,
# the build still succeeds and the portfolio falls back to its empty state.

SUPABASE_URL=https://xxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
