---
/**
 * "Areas We Serve" — in-body, server-rendered internal-linking section.
 * Plain <a> tags to every service-area page so Googlebot has crawlable,
 * in-content referring links (not just nav/footer boilerplate).
 *
 * Props let the heading/intro flex per page without duplicating markup.
 */
import { serviceAreas } from '../data/service-areas';

interface Props {
  heading?: string;
  intro?: string;
}

const {
  heading = 'Areas We Serve',
  intro = 'Based in Montrose and serving gear, canvas, and upholstery repair across the Western Slope. Free local pickup and 3–7 day turnaround in each of these communities:',
} = Astro.props;
---

<section class="areas-served" aria-labelledby="areas-served-heading">
  <div class="wrap">
    <div class="as-head">
      <div class="section-num">§ Service Area</div>
      <h2 id="areas-served-heading">{heading}</h2>
      <p class="as-intro">{intro}</p>
    </div>
    <ul class="as-grid">
      {serviceAreas.map((area) => (
        <li>
          <a href={`/service-areas/${area.slug}/`}>
            <span class="as-city">{area.cityName}, {area.state}</span>
            <span class="as-region">{area.region}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .areas-served {
    padding: 80px 0;
    background: var(--canvas);
    border-top: 2px solid var(--charcoal);
  }
  .as-head { margin-bottom: 36px; max-width: 64ch; }
  .areas-served h2 {
    font-size: clamp(30px, 4.2vw, 52px);
    letter-spacing: -0.03em;
    margin-top: 14px;
    text-wrap: balance;
  }
  .as-intro {
    margin: 22px 0 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink);
  }
  .as-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--rule-strong);
  }
  .as-grid li {
    border-bottom: 1px solid var(--rule-strong);
  }
  .as-grid a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 2px;
    text-decoration: none;
    color: var(--charcoal);
    transition: padding-left 0.14s ease, color 0.14s ease;
  }
  .as-grid a:hover { padding-left: 8px; color: var(--rust); }
  .as-city {
    font-family: var(--f-serif);
    font-weight: 500;
    font-size: clamp(19px, 2.4vw, 24px);
    letter-spacing: -0.01em;
  }
  .as-region {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: right;
    flex-shrink: 0;
  }
  @media (min-width: 700px) {
    .as-grid { grid-template-columns: repeat(2, 1fr); column-gap: 56px; }
  }
  @media (min-width: 1040px) {
    .as-grid { grid-template-columns: repeat(3, 1fr); column-gap: 48px; }
  }
</style>
