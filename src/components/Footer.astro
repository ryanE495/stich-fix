---
import { site } from '../config/site';
import { serviceAreas } from '../data/service-areas';

const serviceAreaLine = site.serviceArea.join(' · ');
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-brand-name">{site.name}</div>
        <p class="footer-brand-line">
          A one-person repair shop in Montrose, Colorado. Heavy-duty gear, canvas, and upholstery — stitched to last.
        </p>
      </div>
      <div>
        <h4>Site</h4>
        <a href="/">Home</a>
        <a href="/services">Services &amp; Pricing</a>
        <a href="/custom-builds">Custom Builds</a>
        <a href="/portfolio">Portfolio</a>
        <a href="/contact">Contact</a>
      </div>
      <div>
        <h4>Reach Me</h4>
        <a href={site.phoneHref}>{site.phoneDisplay}</a>
        <a href="/contact">Send a photo →</a>
        <a href="/contact">{site.location} · {site.hours}</a>
      </div>
    </div>

    <div class="footer-areas">
      <h4>Service Areas</h4>
      <ul class="footer-areas-list">
        {serviceAreas.map((area) => (
          <li>
            <a href={`/service-areas/${area.slug}/`}>{area.cityName}, {area.state}</a>
          </li>
        ))}
      </ul>
    </div>

    <div class="footer-base">
      <span>© {site.name}</span>
      <span>Serving {serviceAreaLine}</span>
    </div>
  </div>
</footer>
