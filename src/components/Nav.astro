---
import { site, nav, type NavKey } from '../config/site';
import { serviceAreas } from '../data/service-areas';

interface Props {
  active?: NavKey;
}

const { active } = Astro.props;
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <img
        class="brand-mark"
        src="https://bswmrfxdadcmuyhmsagv.supabase.co/storage/v1/object/public/portfolio-images/logo-v2.webp"
        alt={`${site.name} logo`}
        width="76"
        height="76"
        loading="eager"
        decoding="async"
      />
      <div class="brand-text">
        {site.name}
        <small>{site.tagline}</small>
      </div>
    </a>

    <div class="nav-links">
      <a href="/" class={active === 'home' ? 'active' : ''}>Home</a>
      <a href="/services" class={active === 'services' ? 'active' : ''}>Services &amp; Pricing</a>
      <a href="/custom-builds" class={active === 'custom-builds' ? 'active' : ''}>Custom Builds</a>
      <a href="/portfolio" class={active === 'portfolio' ? 'active' : ''}>Portfolio</a>
      <div class={`nav-dropdown ${active === 'service-areas' ? 'active' : ''}`}>
        <button
          type="button"
          class="nav-dropdown-trigger"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="nav-service-areas"
        >
          Service Areas
          <span class="nav-dropdown-caret" aria-hidden="true">▾</span>
        </button>
        <div id="nav-service-areas" class="nav-dropdown-panel" role="menu">
          <div class="nav-dropdown-kicker">Western Slope · 13 communities</div>
          <ul class="nav-dropdown-grid">
            {serviceAreas.map((area) => (
              <li role="none">
                <a
                  href={`/service-areas/${area.slug}/`}
                  role="menuitem"
                >
                  {area.cityName}
                  <span class="nav-dd-region">{area.region}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
      <a href="/contact" class={active === 'contact' ? 'active' : ''}>Contact</a>
      <a href={site.phoneHref} class="nav-phone">{site.phoneDisplay}</a>
    </div>

    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <ul class="mobile-menu-list">
        {nav.map((item, i) => (
          <li>
            <a
              href={item.href}
              class={active === item.key ? 'active' : ''}
              data-menu-link
            >
              <span class="mm-label">{item.label}</span>
              <span class="mm-num">{String(i + 1).padStart(2, '0')}</span>
            </a>
          </li>
        ))}
      </ul>

      <div class={`mm-areas ${active === 'service-areas' ? 'is-active' : ''}`}>
        <div class="mm-areas-head">
          <span class="mm-kicker">Service Areas</span>
          <span class="mm-areas-count">{serviceAreas.length} communities</span>
        </div>
        <ul class="mm-areas-list">
          {serviceAreas.map((area) => (
            <li>
              <a href={`/service-areas/${area.slug}/`} data-menu-link>{area.cityName}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="mobile-menu-foot">
        <span class="mm-kicker">Fastest path</span>
        <a href={site.phoneHref} class="btn mobile-menu-phone" data-menu-link>
          Call or Text {site.phoneDisplay}
        </a>
        <span class="mm-hours">{site.hours} · {site.location}</span>
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector<HTMLElement>('.nav');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.querySelector<HTMLElement>('.mobile-menu');
  const dropdown = document.querySelector<HTMLElement>('.nav-dropdown');
  const ddTrigger = document.querySelector<HTMLButtonElement>('.nav-dropdown-trigger');
  const body = document.body;

  if (nav && toggle && menu) {
    const open = () => {
      menu.style.setProperty('--nav-h', nav.offsetHeight + 'px');
      body.classList.add('menu-open');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Close menu');
      menu.setAttribute('aria-hidden', 'false');
    };
    const close = () => {
      body.classList.remove('menu-open');
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Open menu');
      menu.setAttribute('aria-hidden', 'true');
    };

    toggle.addEventListener('click', () => {
      body.classList.contains('menu-open') ? close() : open();
    });

    menu.querySelectorAll<HTMLAnchorElement>('[data-menu-link]').forEach((a) => {
      a.addEventListener('click', close);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && body.classList.contains('menu-open')) close();
    });

    const mq = window.matchMedia('(min-width: 721px)');
    mq.addEventListener('change', (e) => {
      if (e.matches && body.classList.contains('menu-open')) close();
    });
  }

  // Desktop dropdown — open on hover via CSS, click-to-toggle for keyboard / touch
  if (dropdown && ddTrigger) {
    const closeDd = () => {
      dropdown.classList.remove('is-open');
      ddTrigger.setAttribute('aria-expanded', 'false');
    };
    const openDd = () => {
      dropdown.classList.add('is-open');
      ddTrigger.setAttribute('aria-expanded', 'true');
    };
    ddTrigger.addEventListener('click', (e) => {
      e.preventDefault();
      dropdown.classList.contains('is-open') ? closeDd() : openDd();
    });
    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target as Node)) closeDd();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDd();
    });
  }
</script>
